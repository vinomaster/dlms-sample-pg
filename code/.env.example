# ── Server ─────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
BASE_URL=http://localhost:4000
CORS_ORIGIN=http://localhost:3000
IDS_ADMIN=admin
API_TOKEN=dev-token-change-me

# ── PostgreSQL (System of Record) ─────────────────────────────────────────────
PG_HOST=localhost
PG_PORT=5432
PG_DB=dlms
PG_USER=dlms
PG_PASS=dlms
PG_SSL=false

# ── OpenSearch (Search Layer) ──────────────────────────────────────────────────
OPENSEARCH_ENDPOINT=http://localhost:9200
# OPENSEARCH_USER=
# OPENSEARCH_PASS=
OPENSEARCH_REPLICAS=0

# ── S3 / LocalStack ────────────────────────────────────────────────────────────
ATTACHMENTS_BUCKET=dlms-attachments
BACKUP_BUCKET=dlms-backups
S3_ENDPOINT=http://localhost:4566
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# ── Auth ───────────────────────────────────────────────────────────────────────
BASIC_AUTH_ENABLED=true
OAUTH_ENABLED=false
SESSION_SECRET=change-me-in-production

# ── Email ──────────────────────────────────────────────────────────────────────
EMAIL_ENABLED=false
APP_EMAIL=noreply@dlms-sample.local
